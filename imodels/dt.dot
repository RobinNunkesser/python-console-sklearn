digraph RuleTree {
	graph [
		rankdir=TB,
		bgcolor="#f3f3f3",
		splines=false,
		nodesep=0.5,
		ranksep=0.65,
		pad=0.2
	];

	node [
		shape=plaintext,
		fontname="Helvetica",
		fontsize=22
	];

	edge [
		color="#666666",
		penwidth=1.4,
		arrowsize=0.0
	];

	root [label=< <B>IF </B> X<SUB>1</SUB>&gt; 5 >];
	left_split [label=< <B>IF </B>X<SUB>2</SUB>&gt; 6 >];
	right_split [label=< <B>IF </B>X<SUB>2</SUB>&gt; 4 >];

	l1 [label="0.2"];
	l2 [label="0.9"];
	l3 [label="0.8"];
	l4 [label="0.6"];

	root -> left_split;
	root -> right_split;

	left_split -> l1;
	left_split -> l2;

	right_split -> l3;
	right_split -> l4;

	{ rank=same; l1; l2; l3; l4; }
	
}
